{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SDVX B50 Tool",
  "version": "1.2.1",
  "identifier": "net.local.sdvx-b50-tool",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "SDVX B50 Tool",
        "width": 1280,
        "height": 860,
        "minWidth": 1000,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": false,
    "icon": []
  }
}
